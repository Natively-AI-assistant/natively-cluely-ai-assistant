{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text"],
  "testRunner": "vitest",
  "testRunner_comment": "Vitest runner for @stryker-mutator/vitest-runner",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/utils/**/*.ts",
    "electron/utils/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "ignoreStatic": true
}
